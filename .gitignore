# =============================================================================
# Mandi Agent — Root .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
*.tar

# Logs & temporary
*.log
*.ogg

# Generated files
*.pdf

# Claude / AI assistant settings
.claude/settings.local.json

# Temporary / scratch files
scratch/
test_results*.txt
demo_output.txt
update_log.txt

# n8n workflow JSONs are tracked
!mandi_agent/n8n/workflows/*.json

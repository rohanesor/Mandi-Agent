# =============================================================================
# Mandi-Agent Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys

# -- Core AI --
GEMINI_API_KEY=your_gemini_api_key_here

# -- Database (Supabase) --
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# -- Embeddings --
COHERE_API_KEY=your_cohere_api_key_here
# OPENAI_API_KEY=          # Optional fallback for embeddings

# -- Data Sources --
DATA_GOV_API_KEY=your_data_gov_api_key_here
ENAM_API_KEY=your_enam_api_key_here
IMD_API_KEY=your_imd_api_key_here
NEWSAPI_KEY=your_newsapi_key_here
# Get free key at newsapi.org (100 requests/day free)
# GDELT and RSS feeds need no key
# OPENWEATHER_API_KEY=     # Optional fallback for weather
ISRO_MOSDAC_TOKEN=your_isro_mosdac_token_here

# -- Voice (Reverie) --
REVERIE_APP_ID=your_reverie_app_id_here
REVERIE_API_KEY=your_reverie_api_key_here

# -- Automation (n8n) --
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=your_n8n_api_key_here

# -- Guardrails --
# BRAINTRUST_API_KEY=        # Optional - for AI evaluation logging
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# -- Caching --
REDIS_URL=redis://localhost:6379

{
  "webhooks": {
    "advisories": {
      "path": "/webhooks/advisory",
      "method": "POST",
      "description": "WhatsApp voice advisory request",
      "auth": "bearer-token",
      "payload": {
        "farmer_id": "string (required)",
        "phone": "string (whatsapp: prefix)",
        "language": "string (hi, en, kn, ta, te, default: hi)",
        "input_text": "string (optional - farmer query)",
        "input_audio_url": "string (optional - audio from WhatsApp)"
      },
      "response": {
        "advisory_id": "string",
        "text_response": "string",
        "audio_url": "string",
        "session_id": "string",
        "processing_time_ms": "number"
      }
    },
    "price_alerts": {
      "path": "/webhooks/price-crash",
      "method": "POST",
      "description": "Price crash broadcast via Telegram + voice alert",
      "auth": "api-key",
      "payload": {
        "crop": "string",
        "block_id": "string",
        "current_price": "number",
        "forecast_price": "number",
        "drop_pct": "number",
        "affected_farmers": ["string"]
      }
    },
    "emergency_alerts": {
      "path": "/webhooks/spoilage",
      "method": "POST",
      "description": "Spoilage emergency - immediate action required",
      "auth": "api-key",
      "payload": {
        "farmer_id": "string",
        "farmer_phone": "string",
        "crop": "string",
        "spoilage_pct": "number",
        "coordinates": {
          "lat": "number",
          "lng": "number"
        }
      }
    },
    "weather_alerts": {
      "path": "/webhooks/weather-alert",
      "method": "POST",
      "description": "Daily weather forecast for farmer regions",
      "auth": "bearer-token",
      "payload": {
        "block_id": "string",
        "forecast": {
          "temperature": "number",
          "rainfall": "number",
          "wind_speed": "number",
          "advisory": "string"
        }
      }
    },
    "scheme_eligibility": {
      "path": "/webhooks/scheme-check",
      "method": "POST",
      "description": "Government scheme eligibility check",
      "auth": "bearer-token",
      "payload": {
        "farmer_id": "string",
        "land_size": "number",
        "crop_type": "string",
        "income_range": "string"
      }
    },
    "bundle_notifications": {
      "path": "/webhooks/bundle-notification",
      "method": "POST",
      "description": "Bundle formation notification",
      "auth": "api-key",
      "payload": {
        "bundle_id": "string",
        "farmers": ["string"],
        "crop": "string",
        "quantity_quintal": "number",
        "expected_price": "number"
      }
    }
  },
  "revery_config": {
    "enabled": true,
    "endpoint": "https://api.reverieinc.com/v2",
    "auth_header": "Authorization: Bearer",
    "features": {
      "voice_synthesis": {
        "languages": ["hi", "en", "kn", "ta", "te", "mr", "gu"],
        "voice_style": "natural",
        "speed": 1.0,
        "gender": "female"
      },
      "speech_recognition": {
        "languages": ["hi", "en", "kn", "ta", "te"],
        "min_confidence": 0.75
      }
    }
  },
  "auth_schemes": {
    "bearer-token": {
      "type": "http",
      "scheme": "bearer",
      "env_var": "N8N_WEBHOOK_BEARER_TOKEN"
    },
    "api-key": {
      "type": "query",
      "header": "X-API-Key",
      "env_var": "N8N_WEBHOOK_API_KEY"
    }
  }
}

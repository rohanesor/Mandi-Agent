          "type": "main",
          "index": 0
        }]
      ]
    },
    "If Cold Storage Available": {
      "main": [
        [{
          "node": "Book Cold Storage Slot",
          "type": "main",
          "index": 0
        }],
        [{
          "node": "Twilio: Redirect SMS",
          "type": "main",
          "index": 0
        }]
      ]
    },
    "Book Cold Storage Slot": {
